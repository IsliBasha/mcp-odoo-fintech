{
  "name": "mcp-odoo-fintech",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript MCP server for Odoo JSON-2 API with HMAC webhooks and Redis caching",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "MOCK_ODOO=true tsx src/index.ts",
    "build": "tsc && cp -r src/inspector/public dist/inspector/public",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "mcp-odoo": "./dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "typescript": "^5.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.19.0",
    "vitest": "^4.1.9"
  }
}
